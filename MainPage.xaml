<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Pokedex1.MainPage"
             Title="Pokedex">
    
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="View Team" Clicked="OnViewTeamClicked" />
    </ContentPage.ToolbarItems>
    
    <!-- Grid gives a fixed area for the SearchBar/Indicator and a stretchable area for the CollectionView -->
    <Grid Padding="10" RowDefinitions="Auto,Auto,*" ColumnDefinitions="*">
        <!-- Search input -->
        <VerticalStackLayout Grid.Row="0" Padding="20" Spacing="10">
            <!-- Search Bar at the top -->
            <SearchBar x:Name="PokemonSearchBar" 
               Placeholder="Search Pokémon"
               TextChanged="OnSearchTextChanged" />

            <!-- Picker directly below the Search Bar -->
            <Label Text="Filter by Type:" Margin="0,5,0,0" />
            <Picker x:Name="TypePicker" 
            Title="Select a Type"
            SelectedIndexChanged="OnTypeFilterChanged">
                <Picker.Items>
                    <x:String>All</x:String>
                    <x:String>Grass</x:String>
                    <x:String>Fire</x:String>
                    <x:String>Water</x:String>
                    <x:String>Electric</x:String>
                    <x:String>Psychic</x:String>
                    <x:String>Rock</x:String>
                    <x:String>Ground</x:String>
                    <x:String>Flying</x:String>
                    <x:String>Bug</x:String>
                    <x:String>Ice</x:String>
                    <x:String>Dragon</x:String>
                    <x:String>Dark</x:String>   
                </Picker.Items>
            </Picker>
        </VerticalStackLayout>

        <!-- Loading indicator -->
        <ActivityIndicator
            Grid.Row="1"
            x:Name="LoadingIndicator"
            IsVisible="False"
            IsRunning="False"
            HorizontalOptions="Center"
            VerticalOptions="Center" />

        <!-- CollectionView fills remaining space and will scroll automatically -->
        <CollectionView
            Grid.Row="2"
            x:Name="PokeCollection"
            SelectionMode="Single"
            SelectionChanged="OnSelectionChanged"
            ItemsLayout="VerticalList"
            RemainingItemsThreshold="5"
            RemainingItemsThresholdReached="OnRemainingItemsThresholdReached"
            Margin="0,8,0,0">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="8" Margin="4" BackgroundColor="Transparent" StrokeThickness="0">
                        <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                            <Image
                                Source="{Binding ImageUrl}"
                                WidthRequest="56"
                                HeightRequest="56" />
                            <VerticalStackLayout>
                                <Label Text="{Binding Name}" FontSize="16" />
                                <Label Text="{Binding Type}" FontSize="12" TextColor="Gray" />
                                <HorizontalStackLayout Spacing="6">
                                    <Label Text="HP" FontSize="10" />
                                    <ProgressBar Progress="{Binding HP}" ProgressColor="Green" WidthRequest="100" />
                                    <Label Text="{Binding HP, StringFormat='{0:P0}'}" FontSize="10" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </HorizontalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>